{
  "name": "@yank/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "drizzle:generate": "NODE_OPTIONS='--require tsx/cjs' drizzle-kit generate",
    "drizzle:migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@yank/shared": "workspace:*",
    "drizzle-orm": "~0.36.0",
    "postgres": "~3.4.0"
  },
  "devDependencies": {
    "drizzle-kit": "~0.28.0",
    "tsx": "~4.19.0",
    "typescript": "*"
  }
}
